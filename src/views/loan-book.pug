extends layouts/main.pug

block content
  style.
    .dashboard {
      font-family: inherit !important;
    }
    .dashboard *, .dashboard h1, .dashboard h2, .dashboard p, .dashboard span, .dashboard label, .dashboard input, .dashboard select, .dashboard button, .dashboard a {
      font-family: inherit !important;
    }
    
    .header-container {
      display: flex !important;
      width: 100% !important;
      justify-content: space-between !important;
      align-items: flex-start !important;
      padding-bottom: 1.25rem;
      border-b: 1px solid #e2e8f0;
    }
    
    .loan-card, .loan-form {
      background: #ffffff !important;
      border: 1px solid rgba(226, 232, 240, 0.8) !important;
      border-radius: 20px !important;
      padding: 2rem 1.75rem !important;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 10px 15px -3px rgba(0, 0, 0, 0.03) !important;
    }

    .loan-card {
      background: #f8fafc !important;
    }
    
    .book-meta-table {
      display: flex;
      flex-direction: column;
      border: 1px solid #e2e8f0;
      border-radius: 12px;
      overflow: hidden;
      background: #ffffff;
    }
    .meta-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.95rem 1.1rem;
      border-bottom: 1px solid #f1f5f9;
    }
    .meta-row:last-child {
      border-bottom: none;
    }
    .meta-row:nth-child(even) {
      background-color: #f8fafc;
    }
    .meta-label {
      font-size: 0.75rem;
      font-weight: 700;
      color: #64748b;
      letter-spacing: 0.05em;
    }
    .meta-value {
      font-size: 0.9rem;
      font-weight: 600;
      color: #1e293b;
      text-align: right;
      max-width: 65%;
    }
    .meta-value.title-highlight {
      color: var(--primary-color, #4f46e5);
      font-weight: 700;
    }

    .date-grid-container {
      display: grid !important;
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
      gap: 1.5rem !important; /* Espaço generoso entre as duas datas */
    }
    @media (max-width: 640px) {
      .date-grid-container {
        grid-template-columns: 1fr !important;
        gap: 1rem !important;
      }
    }

    .form-group select, .form-group input[type="date"] {
      width: 100%;
      padding: 0.8rem 1rem !important;
      font-size: 0.95rem !important;
      border-radius: 10px !important;
      border: 1px solid #cbd5e1 !important;
      background: #f8fafc !important;
      color: #1e293b !important;
      box-sizing: border-box;
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      outline: none !important;
    }
    .form-group select:focus, .form-group input[type="date"]:focus:not([readonly]) {
      border-color: var(--primary-color, #4f46e5) !important;
      background: #ffffff !important;
      box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1) !important;
    }
    .form-group input[readonly] {
      background: #e2e8f0 !important;
      border-color: #cbd5e1 !important;
      color: #64748b !important;
    }
    .category-badge {
      display: inline-block;
      padding: 0.2rem 0.6rem !important;
      background-color: #e0e7ff !important;
      color: #4f46e5 !important;
      font-size: 0.75rem !important;
      font-weight: 700 !important;
      border-radius: 6px !important;
    }
    .alert-error {
      border-radius: 14px !important;
      box-shadow: 0 4px 12px rgba(239, 68, 68, 0.08) !important;
    }

  main.dashboard(class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8")
    
    //- Cabeçalho Superior
    .header-container
      div
        h1(class="text-3xl font-bold text-gray-900 tracking-tight" style="letter-spacing: -0.03em; margin: 0;") Registrar Empréstimo
        p.subtitle(class="text-gray-500 mt-1" style="font-size: 0.95rem; margin: 0;") Confirme os detalhes do acervo e selecione o usuário para concluir.
      
      //- Botão voltar 
      a.btn-back(
        href="#"
        onclick="window.history.back(); return false;"
        style="display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.5rem 0.85rem; background: #ffffff; color: #4b5563; border: 1px solid #d1d5db; border-radius: 6px; font-size: 0.8rem; font-weight: 600; text-decoration: none; box-shadow: 0 1px 2px rgba(0,0,0,0.05); transition: all 0.2s ease; white-space: nowrap; height: fit-content; margin-top: 4px;"
        onmouseover="this.style.background='#f9fafb'; this.style.borderColor='#9ca3af'; this.style.color='#111827';"
        onmouseout="this.style.background='#ffffff'; this.style.borderColor='#d1d5db'; this.style.color='#4b5563';"
      )
        span ←
        | Voltar ao painel

    //- Grid de Seções 
    .loan-container(class="grid grid-cols-1 md:grid-cols-5 gap-8 items-start")
      
      //- Lado Esquerdo: Card de Informações do Livro 
      .loan-card(class="md:col-span-2 space-y-4")
        h2(class="text-xs font-bold text-gray-400 uppercase tracking-wider flex items-center gap-2" style="margin-bottom: 1rem;") 
          span 📖
          | Especificações do Livro
        
        .book-meta-table
          .meta-row
            span.meta-label Título
            span.meta-value.title-highlight= book.titulo
          
          .meta-row
            span.meta-label Autor
            span.meta-value= book.autor
          
          .meta-row
            span.meta-label Categoria
            span.meta-value
              span.category-badge= book.categ
          
          .meta-row
            span.meta-label Status
            span.meta-value(class=book.qtdDisponivel > 0 ? 'text-emerald-600' : 'text-red-600')
              = book.qtdDisponivel > 0 ? `Disponível (${book.qtdDisponivel} un)` : 'Esgotado'

      //- Formulário de Ação Principal (Ocupa 3 colunas)
      .form-container(class="md:col-span-3")
        if book.qtdDisponivel <= 0
          .alert.alert-error(class="flex items-center gap-3 p-5 bg-red-50 border border-red-200 text-red-800 text-sm font-medium")
            span ❌
            p Este livro está com o estoque esgotado e não pode receber novos empréstimos no momento.
        
        else
          form.loan-form(action="/api/loans" method="POST" class="space-y-6")
            input(type="hidden" name="bookId" value=book.id)

            //- Campo Seleção de Usuário
            .form-group(class="flex flex-col space-y-2")
              label(class="text-xs font-bold text-gray-700 uppercase tracking-wide") Usuário Beneficiário
              select(name="userId" required)
                option(value="") Selecione um usuário cadastrado...
                each user in users
                  option(value=user.id)= `${user.nome} (${user.email})`

            //- Grupo de Datas 
            .date-grid-container
              //- Data de Empréstimo
              .form-group(class="flex flex-col space-y-2")
                label(class="text-xs font-bold text-gray-700 uppercase tracking-wide") Data de Empréstimo
                input(
                  type="date"
                  name="loanDate"
                  required
                  value=loanDate
                  readonly
                )
              
              //- Data de Devolução
              .form-group(class="flex flex-col space-y-2")
                label(class="text-xs font-bold text-gray-700 uppercase tracking-wide") Prazo de Devolução
                input(
                  type="date"
                  name="dueDate"
                  required
                )

            //- Botão Emitir Empréstimo 
            button.btn(
              type="submit" 
              style="width: 100%; display: inline-flex; align-items: center; justify-content: center; background: var(--primary-color, #4f46e5); color: #ffffff; padding: 0.85rem 1.5rem; border-radius: 10px; font-weight: 600; font-size: 0.95rem; border: 1px solid transparent; cursor: pointer; box-shadow: 0 4px 12px rgba(79, 70, 229, 0.15); transition: all 0.2s ease; margin-top: 0.5rem;"
              onmouseover="this.style.background='var(--primary-hover, #4338ca)'; this.style.transform='translateY(-1px)';"
              onmouseout="this.style.background='var(--primary-color, #4f46e5)'; this.style.transform='translateY(0)';"
            ) Emitir Empréstimo