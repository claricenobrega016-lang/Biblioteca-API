extends layouts/main.pug

block content
  //- Navbar
  nav.navbar(style="display: flex; justify-content: space-between; align-items: center; padding: 0.85rem 2rem; background: var(--card-bg); border-bottom: 1px solid var(--border-light); position: sticky; top: 0; z-index: 1000; box-shadow: var(--shadow-sm);")
    .logo(style="font-size: 1.25rem; font-weight: 700; color: var(--text-dark); letter-spacing: -0.025em; display: flex; align-items: center; gap: 0.5rem;") 📚 Biblioteca API
    
    .menu(tabindex="0" style="position: relative; outline: none;")
      button.menu-btn(
        style="display: flex; align-items: center; gap: 0.5rem; background: var(--bg-main); color: var(--text-dark); padding: 0.6rem 1.1rem; border-radius: 50px; border: 1px solid var(--border-light); cursor: pointer; font-weight: 600; font-size: 0.85rem; font-family: inherit; transition: all 0.2s ease;"
        onmouseover="this.style.background='#e2e8f0'; this.style.borderColor='#cbd5e1';"
        onmouseout="this.style.background='var(--bg-main)'; this.style.borderColor='var(--border-light)';"
      )
        span(style="font-size: 1rem; line-height: 1;") ⚙️
        | Opções
        span(style="font-size: 0.65rem; opacity: 0.7; margin-left: 0.2rem;") ▼
      
      .dropdown(style="position: absolute; right: 0; top: calc(100% + 0.5rem); background: var(--card-bg); min-width: 180px; box-shadow: var(--shadow-lg); border-radius: 12px; border: 1px solid var(--border-light); overflow: hidden; z-index: 1100; display: none;")
        a(href="/dashboard", style="display: flex; align-items: center; gap: 0.6rem; padding: 0.75rem 1.25rem; color: var(--text-dark); font-size: 0.875rem; font-weight: 500; text-decoration: none; transition: all 0.2s ease;")
          span.icon-profile 📊 
          | Voltar ao Painel
        a(href="/logout", style="display: flex; align-items: center; gap: 0.6rem; padding: 0.75rem 1.25rem; color: var(--danger-text); background: var(--danger-light); font-size: 0.875rem; font-weight: 600; text-decoration: none; transition: all 0.2s ease; border-top: 1px solid var(--border-light);")
          span.icon-logout 🚪 
          | Sair

  style.
    .menu:focus-within .dropdown, .menu:hover .dropdown { display: block !important; }
    .dropdown a:hover { background: var(--bg-main); color: var(--primary-color) !important; }

  .login-container
    .login-card
      .register-header
        h1 Meus Dados
        p.login-subtitle Mantenha suas informações de perfil atualizadas

      //- Exibe uma badge com o nível de acesso atual do usuário
      div(style="margin-bottom: 2rem;")
        span(class=`badge ${user.funcao === 'admin' ? 'badge-admin' : 'badge-comum'}` style="padding: 0.5rem 1rem; font-size: 0.85rem;")
          | Conta: #{user.funcao === 'admin' ? 'Administrador' : 'Usuário Comum'}

      //- Elemento para exibir mensagens (Sucesso ou Erro)
      #alertMessage.alert-message

      form#editProfileForm(data-user-id=user.id)
        //- Campo Nome
        .form-group
          label(for="nome") Nome completo
          input(type="text", name="nome", id="nome", value=user.nome, placeholder="Seu nome", required)

        //- Campo Email
        .form-group
          label(for="email") Email de acesso
          input(type="email", name="email", id="email", value=user.email, placeholder="seu@email.com", required)

        //- Telefone (Corrigido adicionando value e aplicando escape na Regex)
        .form-group
          label(for="telefone") Telefone
          input(type="tel", name="telefone", id="telefone", value=user.telefone, placeholder="(81) 99999-9999", inputmode="numeric", autocomplete="tel", pattern="^\\(?\\d{2}\\)?\\s?9?\\d{4}-?\\d{4}$", required)
          
        hr(style="border: 0; border-top: 1px solid #eef0f6; margin: 2rem 0 1.5rem 0;")
        
        //- Seção opcional de Nova Senha
        .form-group
          label(for="senha") Nova Senha (Opcional)
          input(type="password", name="senha", id="senha", placeholder="Deixe em branco para não alterar")

        .form-group(style="margin-top: 2rem; display: flex; flex-direction: column; gap: 0.8rem;")
          button.btn-cta(type="submit", id="btnSalvar", style="width: 100%; border: none; cursor: pointer;") Salvar Alterações 💾
          a.btn-secondary(href="/dashboard", style="text-align: center; width: 100%; text-decoration: none;") Voltar ao Painel

  script.
    document.addEventListener('DOMContentLoaded', () => {
      const telefoneInput = document.getElementById('telefone');

      // Executa a máscara logo ao carregar a página se já houver um número salvo
      if(telefoneInput.value) {
        formatarTelefone(telefoneInput);
      }

      telefoneInput.addEventListener('input', (e) => {
        formatarTelefone(e.target);
      });

      function formatarTelefone(input) {
        let value = input.value.replace(/\D/g, '');
        if (value.length > 11) value = value.slice(0, 11);

        if (value.length > 10) {
          value = value.replace(/(\d{2})(\d{5})(\d{4})/, '($1) $2-$3');
        } else if (value.length > 6) {
          value = value.replace(/(\d{2})(\d{4})(\d+)/, '($1) $2-$3');
        } else if (value.length > 2) {
          value = value.replace(/(\d{2})(\d+)/, '($1) $2');
        } else if (value.length > 0) {
          value = value.replace(/(\d+)/, '($1');
        }
        input.value = value;
      }

      document.getElementById('editProfileForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const alertBox = document.getElementById('alertMessage');
        const btnSubmit = document.getElementById('btnSalvar');
        
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData.entries());
        const userId = e.target.getAttribute('data-user-id');

        if (!data.senha) {
          delete data.senha;
        }

        btnSubmit.disabled = true;
        btnSubmit.innerText = "Salvando...";
        alertBox.className = 'alert-message';

        try {
          const response = await fetch(`/api/users/${userId}`, {
            method: 'PATCH', 
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
          
          if (response.ok) {
            alertBox.classList.add('alert-success', 'show');
            alertBox.innerText = 'Perfil atualizado com sucesso! Redirecionando...';
            
            setTimeout(() => {
              window.location.href = '/dashboard';
            }, 3000);
            
          } else {
            const errData = await response.json();
            alertBox.classList.add('alert-error', 'show');
            alertBox.innerText = 'Erro: ' + (errData.message || 'Não foi possível salvar.');
            
            btnSubmit.disabled = false;
            btnSubmit.innerText = "Salvar Alterações 💾";
          }
        } catch (error) {
          console.error('Erro:', error);
          alertBox.className = 'alert-message alert-error show';
          alertBox.innerText = 'Erro de conexão com o servidor.';
          
          btnSubmit.disabled = false;
          btnSubmit.innerText = "Salvar Alterações 💾";
        }
      });
    });