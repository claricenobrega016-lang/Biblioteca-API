extends layouts/main.pug

block content
  main.dashboard(class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8")
    
    .header-admin(style="display: flex; justify-content: space-between; align-items: center; gap: 1rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border-light, #e5e7eb);")
      
      //- Bloco de texto do título
      .header-title
        h1(class="text-3xl font-bold text-gray-900 tracking-tight" style="margin: 0; line-height: 1.2;") Histórico de Empréstimos
        p.subtitle(class="text-gray-500 mt-1" style="margin: 0.25rem 0 0 0;") Visualize o registro completo de todas as movimentações e devoluções do acervo.
      
      
      a.btn-back(
        href="#"
        onclick="window.history.back(); return false;"
        style="display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.5rem 0.85rem; background: #ffffff; color: #4b5563; border: 1px solid #d1d5db; border-radius: 6px; font-size: 0.8rem; font-weight: 600; text-decoration: none; box-shadow: 0 1px 2px rgba(0,0,0,0.05); transition: all 0.2s ease; white-space: nowrap; height: fit-content;"
        onmouseover="this.style.background='#f9fafb'; this.style.borderColor='#9ca3af'; this.style.color='#111827';"
        onmouseout="this.style.background='#ffffff'; this.style.borderColor='#d1d5db'; this.style.color='#4b5563';"
      )
        span(style="font-size: 0.9rem; line-height: 1;") ⟵
        | Voltar ao Painel

    //- Bloco de Tabela
    if loans && loans.length > 0
      .table-container(class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden")
        .overflow-x-auto
          table.admin-table(class="min-w-full divide-y divide-gray-200 text-left text-sm")
            thead(class="bg-gray-50 text-gray-500 font-medium")
              tr
                th(class="px-6 py-4") Usuário
                th(class="px-6 py-4") Livro
                th(class="px-6 py-4") Empréstimo
                th(class="px-6 py-4") Prazo Limite
                th(class="px-6 py-4") Devolução
                th(class="px-6 py-4 text-center") Status

            tbody(class="divide-y divide-gray-200 text-gray-700")
              each loan in loans
                tr(class="hover:bg-gray-50 transition")
                  //- Usuário
                  td(class="px-6 py-4 font-medium text-gray-900")= loan.user ? loan.user.nome : '—'
                  
                  //- Livro
                  td(class="px-6 py-4 text-gray-600 font-medium")= loan.book ? loan.book.titulo : '—'
                  
                  //- Datas formatadas
                  td(class="px-6 py-4 text-gray-500")= loan.loanDate ? new Date(loan.loanDate).toLocaleDateString('pt-BR') : '—'
                  td(class="px-6 py-4 text-gray-500")= loan.dueDate ? new Date(loan.dueDate).toLocaleDateString('pt-BR') : '—'
                  
                  //- Data de devolução
                  td(class="px-6 py-4 text-gray-600 font-medium")
                    if loan.returnDate
                      = new Date(loan.returnDate).toLocaleDateString('pt-BR')
                    else
                      span(class="text-gray-400 italic font-normal") Não devolvido
                  
                  
                  td(class="px-6 py-4 text-center")
                    if loan.status === 'ATIVO'
                      span.badge(class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800") ATIVO
                    else if loan.status === 'DEVOLVIDO'
                      span.badge(class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800") DEVOLVIDO
                    else
                      span.badge(class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800") ATRASADO
    else
      
      .empty(class="text-center py-16 bg-white border border-gray-200 rounded-xl shadow-sm max-w-md mx-auto mt-8")
        div(class="text-4xl mb-3 text-gray-300") 📋
        h3(class="text-lg font-medium text-gray-900 mb-1") Nenhum histórico encontrado
        p(class="text-gray-500 text-sm px-6") Até o momento, não existem registros de empréstimos finalizados ou ativos salvos no banco de dados.

  footer.footer(class="text-center py-8 text-sm text-gray-400 mt-12 border-t border-gray-100")
    p Sistema de Biblioteca © 2026