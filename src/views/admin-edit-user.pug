extends layouts/main.pug

block content
  //- Navbar
  nav.navbar(style="display: flex; justify-content: space-between; align-items: center; padding: 0.85rem 2rem; background: var(--card-bg, #ffffff); border-bottom: 1px solid var(--border-light, #e5e7eb); position: sticky; top: 0; z-index: 1000; box-shadow: var(--shadow-sm, 0 1px 2px rgba(0,0,0,0.05));")
    .logo(style="font-size: 1.25rem; font-weight: 700; color: var(--text-dark, #1f2937); letter-spacing: -0.025em; display: flex; align-items: center; gap: 0.5rem;") 
      span 📚
      | Biblioteca API
      span(style="font-size: 0.75rem; font-weight: 400; background: #e0e7ff; color: #4338ca; padding: 0.15rem 0.5rem; border-radius: 50px; margin-left: 0.25rem;") Admin
    
    .menu(tabindex="0" style="position: relative; outline: none;")
      button.menu-btn(
        style="display: flex; align-items: center; gap: 0.5rem; background: var(--bg-main, #f3f4f6); color: var(--text-dark, #1f2937); padding: 0.6rem 1.1rem; border-radius: 50px; border: 1px solid var(--border-light, #e5e7eb); cursor: pointer; font-weight: 600; font-size: 0.85rem; font-family: inherit; transition: all 0.2s ease;"
        onmouseover="this.style.background='#e2e8f0'; this.style.borderColor='#cbd5e1';"
        onmouseout="this.style.background='var(--bg-main, #f3f4f6)'; this.style.borderColor='var(--border-light, #e5e7eb)';"
      )
        span(style="font-size: 1rem; line-height: 1;") ⚙️
        | Opções
        span(style="font-size: 0.65rem; opacity: 0.7; margin-left: 0.2rem;") ▼
      
      .dropdown(style="position: absolute; right: 0; top: calc(100% + 0.5rem); background: var(--card-bg, #ffffff); min-width: 180px; box-shadow: var(--shadow-lg, 0 10px 15px -3px rgba(0,0,0,0.1)); border-radius: 12px; border: 1px solid var(--border-light, #e5e7eb); overflow: hidden; z-index: 1100; display: none;")
        a(href="/dashboard", style="display: flex; align-items: center; gap: 0.6rem; padding: 0.75rem 1.25rem; color: var(--text-dark, #1f2937); font-size: 0.875rem; font-weight: 500; text-decoration: none; transition: all 0.2s ease;")
          span 📊
          | Voltar ao Painel
        a(href="/logout", style="display: flex; align-items: center; gap: 0.6rem; padding: 0.75rem 1.25rem; color: #dc2626; background: #fef2f2; font-size: 0.875rem; font-weight: 600; text-decoration: none; transition: all 0.2s ease; border-top: 1px solid var(--border-light, #e5e7eb);")
          span 🚪 
          | Sair

  style.
    .menu:focus-within .dropdown, .menu:hover .dropdown { display: block !important; }
    .dropdown a:hover { background: var(--bg-main, #f3f4f6); color: #4338ca !important; }

  main.dashboard(class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-12")
    .login-container
      .login-card(class="bg-white border border-gray-200 rounded-2xl shadow-sm p-6 sm:p-8 space-y-6")
        
        //- Cabeçalho e Badge de Estado Atual
        .register-header(class="border-b border-gray-100 pb-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3")
          div
            h1(class="text-2xl font-bold text-gray-900 tracking-tight") Dados do Usuário
            p.login-subtitle(class="text-gray-500 text-sm mt-0.5") Gerenciamento de nível de acesso.
          
        //- Caixa de Alerta Dinâmica
        #alertMessage.alert-message(class="hidden p-4 rounded-xl text-sm font-medium shadow-sm transition-all duration-300")

        //- Formulário
        form#editUserForm(data-user-id=user.id class="space-y-5")

          //- Nome Completo
          .form-group(class="flex flex-col space-y-1.5")
            label(class="text-sm font-semibold text-gray-600") Nome Completo
            input(type="text", value=user.nome, disabled, class="w-full px-3 py-2 bg-gray-50 border border-gray-200 text-gray-500 rounded-lg text-sm cursor-not-allowed outline-none select-none font-medium")

          //- Email
          .form-group(class="flex flex-col space-y-1.5")
            label(class="text-sm font-semibold text-gray-600") Endereço de Email
            input(type="email", value=user.email, disabled, class="w-full px-3 py-2 bg-gray-50 border border-gray-200 text-gray-500 rounded-lg text-sm cursor-not-allowed outline-none select-none")

          //- Telefone (Corrigido: adicionado value, disabled, estilização cinza e escape no pattern)
          .form-group(class="flex flex-col space-y-1.5")
            label(class="text-sm font-semibold text-gray-600") Telefone
            input(type="tel", name="telefone", id="telefone", value=user.telefone, disabled, class="w-full px-3 py-2 bg-gray-50 border border-gray-200 text-gray-500 rounded-lg text-sm cursor-not-allowed outline-none select-none", inputmode="numeric", autocomplete="tel", pattern="^\\(?\\d{2}\\)?\\s?9?\\d{4}-?\\d{4}$")

          //- Select Interativo 
          .form-group(class="flex flex-col space-y-1.5")
            label(for="funcao" class="text-sm font-semibold text-gray-700") Função no Sistema
            select(name="funcao", id="funcao", required, class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm text-gray-800 font-medium transition")
              option(value="comum" selected=user.funcao === 'comum') Usuário Comum (Leitor)
              option(value="admin" selected=user.funcao === 'admin') Administrador (Total)

          .form-group(style="margin-top: 2rem; display: flex; flex-direction: column; gap: 0.8rem;")
            button.btn-cta(type="submit" id="btnSalvar" class="w-full px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-medium text-sm rounded-lg shadow-sm transition duration-150 disabled:opacity-50 disabled:cursor-not-allowed" style="border: none; cursor: pointer;") Salvar Alteração
            a.btn-secondary(href="/dashboard" class="w-full px-5 py-2.5 bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 font-medium text-sm rounded-lg shadow-sm text-center transition duration-150" style="text-decoration: none;") Cancelar

  script.
    document.addEventListener('DOMContentLoaded', () => {
      const telefoneInput = document.getElementById('telefone');

      // Formata o número inicial recebido do banco de dados
      if (telefoneInput && telefoneInput.value) {
        let value = telefoneInput.value.replace(/\D/g, '');
        if (value.length > 11) value = value.slice(0, 11);

        if (value.length > 10) {
          value = value.replace(/(\d{2})(\d{5})(\d{4})/, '($1) $2-$3');
        } else if (value.length > 6) {
          value = value.replace(/(\d{2})(\d{4})(\d+)/, '($1) $2-$3');
        } else if (value.length > 2) {
          value = value.replace(/(\d{2})(\d+)/, '($1) $2');
        } else if (value.length > 0) {
          value = value.replace(/(\d+)/, '($1');
        }
        telefoneInput.value = value;
      }

      document.getElementById('editUserForm').addEventListener('submit', async (e) => {
        e.preventDefault();

        const alertBox = document.getElementById('alertMessage');
        const btn = document.getElementById('btnSalvar');

        // Como o telefone está "disabled", o FormData nativo não o captura automaticamente.
        // Capturamos os dados do formulário e reinserimos o valor do telefone manualmente para a API.
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData.entries());
        data.telefone = telefoneInput.value; 

        const userId = e.target.dataset.userId;

        btn.disabled = true;
        btn.innerText = "Salvando...";
        
        alertBox.className = 'hidden p-4 rounded-xl text-sm font-medium shadow-sm transition-all duration-300';

        try {
          const response = await fetch(`/api/users/${userId}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });

          if (response.ok) {
            alertBox.className = 'p-4 rounded-xl text-sm font-medium shadow-sm transition-all duration-300 bg-emerald-50 border border-emerald-200 text-emerald-800';
            alertBox.innerText = 'Usuário atualizado com sucesso! Redirecionando...';

            setTimeout(() => {
              window.location.href = '/dashboard';
            }, 2000);

          } else {
            const err = await response.json();
            alertBox.className = 'p-4 rounded-xl text-sm font-medium shadow-sm transition-all duration-300 bg-red-50 border border-red-200 text-red-800';
            alertBox.innerText = err.message || 'Erro ao atualizar usuário';

            btn.disabled = false;
            btn.innerText = "Salvar Alteração";
          }

        } catch (error) {
          console.error(error);
          alertBox.className = 'p-4 rounded-xl text-sm font-medium shadow-sm transition-all duration-300 bg-red-50 border border-red-200 text-red-800';
          alertBox.innerText = 'Erro de conexão com o servidor.';

          btn.disabled = false;
          btn.innerText = "Salvar Alteração";
        }
      });
    });