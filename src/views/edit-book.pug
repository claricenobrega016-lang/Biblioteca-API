extends layouts/main.pug

block content
  //- Navbar Estruturada
  nav.navbar(style="display: flex; justify-content: space-between; align-items: center; padding: 0.85rem 2rem; background: var(--card-bg); border-bottom: 1px solid var(--border-light); position: sticky; top: 0; z-index: 1000; box-shadow: var(--shadow-sm);")
    .logo(style="font-size: 1.25rem; font-weight: 700; color: var(--text-dark); letter-spacing: -0.025em; display: flex; align-items: center; gap: 0.5rem;")
      span 📚 
      | Biblioteca API (Admin)
    
    .menu(tabindex="0" style="position: relative; outline: none;")
      button.menu-btn(
        style="display: flex; align-items: center; gap: 0.5rem; background: var(--bg-main); color: var(--text-dark); padding: 0.6rem 1.1rem; border-radius: 50px; border: 1px solid var(--border-light); cursor: pointer; font-weight: 600; font-size: 0.85rem; font-family: inherit; transition: all 0.2s ease;"
        onmouseover="this.style.background='#e2e8f0'; this.style.borderColor='#cbd5e1';"
        onmouseout="this.style.background='var(--bg-main)'; this.style.borderColor='var(--border-light)';"
      )
        span(style="font-size: 1rem; line-height: 1;") ⚙️
        | Opções
        span(style="font-size: 0.65rem; opacity: 0.7; margin-left: 0.2rem;") ▼
      
      .dropdown(style="position: absolute; right: 0; top: calc(100% + 0.5rem); background: var(--card-bg); min-width: 180px; box-shadow: var(--shadow-lg); border-radius: 12px; border: 1px solid var(--border-light); overflow: hidden; z-index: 1100; display: none;")
        a(href="/dashboard", style="display: flex; align-items: center; gap: 0.6rem; padding: 0.75rem 1.25rem; color: var(--text-dark); font-size: 0.875rem; font-weight: 500; text-decoration: none; transition: all 0.2s ease;")
          span.icon-profile 📊 
          | Voltar ao Painel
        a(href="/logout", style="display: flex; align-items: center; gap: 0.6rem; padding: 0.75rem 1.25rem; color: var(--danger-text); background: var(--danger-light); font-size: 0.875rem; font-weight: 600; text-decoration: none; transition: all 0.2s ease; border-top: 1px solid var(--border-light);")
          span.icon-logout 🚪 
          | Sair

  style.
    .menu:focus-within .dropdown, .menu:hover .dropdown { display: block !important; }
    .dropdown a:hover { background: var(--bg-main); color: var(--primary-color) !important; }

  .login-container
    .login-card.register-card
      .register-header
        h1 Atualizar Livro
        p.login-subtitle Insira as informações para atualizar o acervo da biblioteca

      #alertMessage.alert-message

      form#addBookForm(data-id=book.id)
        //- Linha 1: Título do Livro
        .form-group
          label(for="titulo") Título do Livro
          input(type="text", name="titulo", id="titulo", value=book.titulo, required)

        //- Linha 2: Autor e Categoria
        .form-row
          .form-group
            label(for="autor") Autor
            input(type="text", name="autor", id="autor", value=book.autor, required)

          .form-group
            label(for="categ") Categoria / Gênero
            input(type="text", name="categ", id="categ", value=book.categ, required)

        //- Linha 3: Ano de Publicação e Quantidades
        .form-row
          .form-group
            label(for="anoPub") Ano de Lançamento
            input(type="number", name="anoPub", id="anoPub", min="0", max="2026", value=book.anoPub, required)

          .form-group
            label(for="qtdDisponivel") Quantidade Disponível
            input(type="number", name="qtdDisponivel", id="qtdDisponivel", min="0", value=book.qtdDisponivel, required)

          .form-group
            label(for="qtdTotal") Quantidade Total
            input(type="number", name="qtdTotal", id="qtdTotal", min="0", value=book.qtdTotal, required)

        
        .form-group(style="display: flex;")
          button.btn-cta(type="submit" id="btnSalvar" style="border: none; cursor: pointer;") Salvar Atualizações 💾
          a.btn-secondary(href="/dashboard" style="text-decoration: none;") Cancelar

  script.
    document.getElementById('addBookForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const alertBox = document.getElementById('alertMessage');
      const btnSubmit = document.getElementById('btnSalvar');
      
      const formData = new FormData(e.target);
      const data = Object.fromEntries(formData.entries());
      
      data.anoPub = parseInt(data.anoPub, 10);
      data.qtdDisponivel = parseInt(data.qtdDisponivel, 10);
      data.qtdTotal = parseInt(data.qtdTotal, 10);

      btnSubmit.disabled = true;
      btnSubmit.innerText = "Salvando Atualizações...";
      alertBox.className = 'alert-message';

      try {
        const bookId = e.target.getAttribute('data-id');
        
        const response = await fetch(`/api/books/${bookId}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        
        if (response.ok) {
          alertBox.classList.add('alert-success', 'show');
          alertBox.innerText = 'Livro atualizado com sucesso! Redirecionando...';
          
          setTimeout(() => {
            window.location.href = '/dashboard';
          }, 3000);
          
        } else {
          const errData = await response.json();
          alertBox.classList.add('alert-error', 'show');
          alertBox.innerText = 'Erro: ' + (errData.message || 'Não foi possível atualizar o livro.');
          
          btnSubmit.disabled = false;
          btnSubmit.innerText = "Salvar Atualizações 💾";
        }
      } catch (error) {
        console.error('Erro na requisição:', error);
        alertBox.className = 'alert-message alert-error show';
        alertBox.innerText = 'Erro de conexão com o servidor.';
        
        btnSubmit.disabled = false;
        btnSubmit.innerText = "Salvar Atualizações 💾";
      }
    });